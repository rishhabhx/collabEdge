    <mxCell id="note4" value="&lt;b&gt;5 Key Design Decisions&lt;/b&gt;&lt;hr/&gt;&lt;b&gt;D1:&lt;/b&gt; Relay split from Backend&lt;br/&gt;&lt;b&gt;D2:&lt;/b&gt; Offline-first IndexedDB&lt;br/&gt;&lt;b&gt;D3:&lt;/b&gt; Shared events.ts constants&lt;br/&gt;&lt;b&gt;D4:&lt;/b&gt; Nginx single entry point&lt;br/&gt;&lt;b&gt;D5:&lt;/b&gt; Repository pattern for DB&lt;br/&gt;&lt;br/&gt;&lt;i&gt;Each decision explained in&lt;br/&gt;Section 4 of the SDD.&lt;/i&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Arial;fontSize=10;spacingLeft=6;spacingTop=6;" vertex="1" parent="1">
