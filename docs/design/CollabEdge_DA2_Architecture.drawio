    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- TITLE -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <mxCell id="title" value="&lt;b&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;CollabEdge — DA2 Software Architecture Diagram&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px; color: #64748B;&quot;&gt;Layered · Client-Server · Event-Driven  |  Design Principles: Abstraction · Modularity · Cohesion · Low Coupling&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Arial;" vertex="1" parent="1">
      <mxGeometry x="400" y="20" width="860" height="50" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- NOTE 1 — DESIGN PRINCIPLES (top-left) -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <mxCell id="note1_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFBEB;strokeColor=#CA8A04;strokeWidth=2;" vertex="1" parent="1">
      <mxGeometry x="20" y="80" width="230" height="230" as="geometry" />
    </mxCell>
    <mxCell id="note1" value="&lt;b&gt;Design Principles Applied&lt;/b&gt;&lt;hr/&gt;&lt;b&gt;Abstraction:&lt;/b&gt; Every service/hook hides its implementation. Canvas, WebSocket, Storage all behind clean facades.&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Modularity:&lt;/b&gt; 3 independent deployable services. Frontend split by feature folder.&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Cohesion:&lt;/b&gt; SceneService only touches scenes. RoomService only touches rooms.&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Low Coupling:&lt;/b&gt; events.ts is the only shared contract. No cross-service imports." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Arial;fontSize=10;spacingLeft=6;spacingRight=6;spacingTop=6;" vertex="1" parent="1">
      <mxGeometry x="26" y="86" width="218" height="218" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- NOTE 2 — WEBSOCKET EVENTS (top-right) -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <mxCell id="note2_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFBEB;strokeColor=#CA8A04;strokeWidth=2;" vertex="1" parent="1">
      <mxGeometry x="1410" y="80" width="220" height="200" as="geometry" />
    </mxCell>
    <mxCell id="note2" value="&lt;b&gt;WebSocket Events&lt;/b&gt;&lt;br/&gt;&lt;i&gt;shared/events.ts&lt;/i&gt;&lt;hr/&gt;emit: element:create&lt;br/&gt;emit: element:update&lt;br/&gt;emit: element:delete&lt;br/&gt;emit: cursor:move&lt;br/&gt;on ← user:join&lt;br/&gt;on ← user:leave&lt;br/&gt;on ← element:create&lt;br/&gt;on ← element:update" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Arial;fontSize=10;spacingLeft=6;spacingTop=6;" vertex="1" parent="1">
      <mxGeometry x="1416" y="86" width="208" height="188" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- NOTE 3 — REST API (far right) -->
