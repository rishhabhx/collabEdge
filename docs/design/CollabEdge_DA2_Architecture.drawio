    <mxCell id="note3_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFBEB;strokeColor=#CA8A04;strokeWidth=2;" vertex="1" parent="1">
      <mxGeometry x="1410" y="300" width="220" height="195" as="geometry" />
