    <mxCell id="note3" value="&lt;b&gt;REST API Endpoints&lt;/b&gt;&lt;hr/&gt;POST   /api/rooms&lt;br/&gt;GET    /api/rooms/:code&lt;br/&gt;POST   /api/scenes&lt;br/&gt;GET    /api/scenes/:id&lt;br/&gt;PUT    /api/scenes/:id&lt;br/&gt;DELETE /api/scenes/:id&lt;br/&gt;GET    /health&lt;br/&gt;GET    /api/relay/health" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontFamily=Arial;fontSize=10;spacingLeft=6;spacingTop=6;" vertex="1" parent="1">
      <mxGeometry x="1416" y="306" width="208" height="183" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- NOTE 4 — DESIGN DECISIONS (bottom-left) -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <mxCell id="note4_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFBEB;strokeColor=#CA8A04;strokeWidth=2;" vertex="1" parent="1">
